*.tar.gz
*.tgz
*.zip
*.dmg
*.dylib
/tmp/
qol-*/

# staged maps / skins if a user ever runs from a working copy
maps/
uifiles/

# editor / OS cruft
.DS_Store
*.swp
*~

# python
__pycache__/
*.pyc

__pycache__/
*.pyc
.bottles/
test/
testlogs/
